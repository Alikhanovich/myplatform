# =====================================================================
#  .env namuna — bu faylni .env ga nusxalab, qiymatlarni to'ldiring.
#  HAQIQIY .env hech qachon git'ga kommit qilinmaydi (.gitignore'da).
# =====================================================================

# --- Qaysi settings moduli ishlatiladi ---
#   Lokal dev:  config.settings.dev   (default)
#   Production: config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Django asoslari ---
# Yangi kalit: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Vergul bilan ajratilgan domenlar (prod uchun majburiy)
ALLOWED_HOSTS=localhost,127.0.0.1

# Render domeni (prod) — CSRF uchun, https:// bilan
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# --- Ma'lumotlar bazasi ---
# Lokal dev'da bo'sh qoldiring -> SQLite ishlatiladi.
# Prod (Render Postgres):
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Admin URL prefiksi (xavfsizlik: /admin emas) ---
ADMIN_URL=studio-panel/

# --- Cloudinary (faqat PROD media uchun) ---
# https://cloudinary.com -> Dashboard -> Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email (contact form xabarlari) ---
# SMTP orqali yuborish uchun:
#   1. EMAIL_BACKEND ni smtp.EmailBackend ga o'zgartiring
#   2. Gmail'da: Google Account → Security → App Passwords → 16 belgilik parol yarating
#   3. EMAIL_HOST_USER va EMAIL_HOST_PASSWORD ni to'ldiring
#
# Konsol (dev fallback) — xabarlar terminalga bosiladi:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Gmail SMTP uchun:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
# Qaerga / qaerdan xat keladi
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
CONTACT_RECIPIENT_EMAIL=your-gmail@gmail.com
